{
  "name": "forage/theme",
  "description": "Forage Theme",
  "license": "GPLv3",
  "autoload": {
    "psr-4": {
      "Forage\\": "app/"
    }
  },
  "require": {
    "php": ">=8.3",
    "illuminate/view": "^13",
    "illuminate/support": "^13"
  },
  "scripts": {
    "lint": "phpcs",
    "format": "phpcbf"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "*",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
